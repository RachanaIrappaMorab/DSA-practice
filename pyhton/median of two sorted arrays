class Solution(object):
    def findMedianSortedArrays(self, nums1, nums2):
        """
        :type nums1: List[int]
        :type nums2: List[int]
        :rtype: float
        """
        nums1.extend(nums2)
        nums1.sort()
        left=0
        right=len(nums1)-1
        mid=(left+right)//2
        if len(nums1)%2==0:
            return((nums1[mid]+nums1[mid+1])/2.0)
        else:
            return(nums1[mid])
