class Solution(object):
    def majorityElement(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        dic={}
        great=0
        b=0
        for i in nums:
            dic[i]=dic.get(i,0)+1
        for i in dic.keys():
            if dic[i]>great:
                great=dic[i]
                b=i
        return b
        
