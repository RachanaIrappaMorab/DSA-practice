class Solution(object):
    def majorityElement(self, nums):
        """
        :type nums: List[int]
        :rtype: List[int]
        """ 
        dic={}
        arr=[]
        for i in nums:
            dic[i]=dic.get(i,0)+1
        for i in dic.keys():
            if dic[i]>len(nums)//3:
                arr.append(i)
        return arr
        

        
