class Solution(object):
    def reverse(self, x):
        """
        :type x: int
        :rtype: int
        """
        if x<0:
            r=int(str(abs(x))[::-1])
            r=r*-1
        else:
            r=int(str(x)[::-1])
        if -2**31<=r<=2**31-1:
            return r
        else:
            return 0
        
