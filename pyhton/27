class Solution(object):
    def removeElement(self, nums, val):
        """
        :type nums: List[int]
        :type val: int
        :rtype: int
        """
        count=0
        n=len(nums)
        for i in range(0,n):
            if nums[i]!=val:
                nums[count]=nums[i]
                count+=1
        return count
        return nums[:count]
        
        
