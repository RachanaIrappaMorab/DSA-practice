class Solution(object):
    def canConstruct(self, ransomNote, magazine):
        """
        :type ransomNote: str
        :type magazine: str
        :rtype: bool
        """
        dic={}
        dic2={}
        arr=[]
        for i in ransomNote:
            dic[i]=dic.get(i,0)+1
        for i in magazine:
            dic2[i]=dic2.get(i,0)+1
        for i,j in dic.items():
             if dic2.get(i, 0) < j:
                return False
        return True

           

